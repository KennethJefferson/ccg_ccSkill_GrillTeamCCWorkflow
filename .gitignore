# Dependencies
node_modules/
.npm/
.pnp/
.pnp.js
.yarn/

# Build / cache
dist/
build/
*.tsbuildinfo
.cache/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment / secrets
.env
.env.*
!.env.example
*.local

# PI / team-bridge runtime state (not source)
.pi/state/
.pi/teams/*.run.json

# Runtime grill outputs (a run's report/snapshot/tree are products, not source)
__solutions/*/grill-report.md
__solutions/*/tree.json
__solutions/*/evidence/
__solutions/*/rounds/
__solutions/*/raw/
__solutions/*/run-manifest.json

# OS / editor cruft
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*~

# Temp
*.tmp
*.temp
__temp/
